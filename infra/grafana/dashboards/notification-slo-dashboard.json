{
  "title": "Notification and Crawler SLO",
  "uid": "notification-crawler-slo",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {"type":"timeseries","title":"First-attempt p95 (seconds)","gridPos":{"h":8,"w":12,"x":0,"y":0},"targets":[{"expr":"histogram_quantile(0.95, sum by (le) (rate(notification_outbox_claim_to_attempt_seconds_bucket[5m])))","refId":"A"}]},
    {"type":"timeseries","title":"Provider latency p95 (seconds)","gridPos":{"h":8,"w":12,"x":12,"y":0},"targets":[{"expr":"histogram_quantile(0.95, sum by (le, provider) (rate(notification_provider_latency_seconds_bucket[5m])))","refId":"A"}]},
    {"type":"timeseries","title":"Outbox queue depth by channel","gridPos":{"h":8,"w":12,"x":0,"y":8},"targets":[{"expr":"notification_outbox_queue_depth","refId":"A"}]},
    {"type":"timeseries","title":"Crawler freshness age (seconds)","gridPos":{"h":8,"w":12,"x":12,"y":8},"targets":[{"expr":"crawler_data_freshness_age_seconds","refId":"A"}]},
    {"type":"stat","title":"DLQ entries (last 10m)","gridPos":{"h":5,"w":8,"x":0,"y":16},"targets":[{"expr":"increase(notification_outbox_dlq_total[10m])","refId":"A"}]},
    {"type":"stat","title":"Open provider circuits (last 10m)","gridPos":{"h":5,"w":8,"x":8,"y":16},"targets":[{"expr":"increase(notification_provider_circuit_open_total[10m])","refId":"A"}]},
    {"type":"stat","title":"Crawler stale flag","gridPos":{"h":5,"w":8,"x":16,"y":16},"targets":[{"expr":"crawler_data_stale","refId":"A"}]}
  ]
}
