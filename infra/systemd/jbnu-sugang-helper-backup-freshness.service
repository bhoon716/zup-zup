[Unit]
Description=Verify JBNU Sugang Helper backup freshness
After=network-online.target
Wants=network-online.target
OnFailure=jbnu-sugang-helper-backup-failure@%n.service

[Service]
Type=oneshot
User=root
EnvironmentFile=/etc/jbnu-sugang-helper/backup.env
ExecStart=/usr/bin/env bash -c 'exec "$${JBNU_PROJECT_ROOT}/infra/scripts/verify-backup-freshness.sh"'
