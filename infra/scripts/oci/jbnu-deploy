#!/usr/bin/env bash
set -euo pipefail

sha="${1:-}"
staging_dir="${2:-}"
if [[ ! "${sha}" =~ ^[0-9a-f]{40}$ ]]; then
  echo "invalid release SHA" >&2
  exit 1
fi
if [[ ! "${staging_dir}" =~ ^/opt/jbnu-sugang-helper-staging/[0-9a-f]{40}$ ]] \
  || [ "${staging_dir##*/}" != "${sha}" ]; then
  echo "invalid staging path" >&2
  exit 1
fi
exec /usr/local/libexec/jbnu-sugang-helper/deploy-release "${sha}" "${staging_dir}"
