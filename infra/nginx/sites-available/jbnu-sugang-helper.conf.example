# Render <API_HOST> before installing this file as a host Nginx site.
# Nginx itself runs on the OCI host; it is not a Compose service.

server {
    listen 80;
    listen [::]:80;
    server_name <API_HOST>;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name <API_HOST>;

    ssl_certificate /etc/letsencrypt/live/<API_HOST>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<API_HOST>/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 10m;

    # Public, sanitized readiness for the external uptime monitor.
    location = /health/ready {
        proxy_pass http://127.0.0.1:8081/actuator/health/readiness;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location ~ ^/api/auth(?:/|$) {
        limit_req zone=sugang_auth burst=5 nodelay;
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/snippets/jbnu-sugang-helper-proxy.conf;
    }

    location ~ ^/api/v1/notifications(?:/|$) {
        limit_req zone=sugang_notification burst=10 nodelay;
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/snippets/jbnu-sugang-helper-proxy.conf;
    }

    location ~ ^/api/v1/crawling(?:/|$) {
        limit_req zone=sugang_crawler burst=2 nodelay;
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/snippets/jbnu-sugang-helper-proxy.conf;
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        include /etc/nginx/snippets/jbnu-sugang-helper-proxy.conf;
    }
}
