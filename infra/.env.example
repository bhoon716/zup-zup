# Application
APP_IMAGE_NAME=sugang-helper
APP_CONTAINER_NAME=sugang-helper-app
APP_PORT_HOST=8080
APP_PORT_CONTAINER=8080

# Database
DB_IMAGE=mysql:8.0
DB_CONTAINER_NAME=sugang-helper-mysql
DB_DATABASE=sugang_helper
DB_PORT_HOST=3306
DB_PORT_CONTAINER=3306
DB_ROOT_PASSWORD=password

# Redis
REDIS_IMAGE=redis:6-alpine
REDIS_CONTAINER_NAME=sugang-helper-redis
REDIS_PORT_HOST=6379
REDIS_PORT_CONTAINER=6379
REDIS_PASSWORD=password

# Monitoring
PROMETHEUS_CONTAINER_NAME=sugang-helper-prometheus
PROMETHEUS_PORT_HOST=9090
PROMETHEUS_PORT_CONTAINER=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_CONTAINER_NAME=sugang-helper-grafana
GRAFANA_PORT_HOST=3001
GRAFANA_PORT_CONTAINER=3000

# Firebase (FCM) - required by server/docker-compose.yml volumes
FIREBASE_CONFIG_PATH=./secrets/firebase-key.json

# Timezone
TZ=Asia/Seoul
