# Application
APP_IMAGE_NAME=sugang-helper-app
APP_CONTAINER_NAME=sugang-helper-app
APP_PORT_HOST=8080
APP_PORT_CONTAINER=8080

# Database
DB_IMAGE=mysql:8.0
DB_CONTAINER_NAME=sugang-helper-mysql
DB_DATABASE=sugang_helper
DB_PORT_HOST=3306
DB_PORT_CONTAINER=3306
DB_ROOT_PASSWORD=password
DB_JDBC_URL=jdbc:mysql://db:3306/sugang_helper?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_RUNTIME_USER=sugang_runtime
DB_RUNTIME_PASSWORD=change-this-runtime-password
DB_MIGRATOR_USER=sugang_migrator
DB_MIGRATOR_PASSWORD=change-this-migrator-password
DB_BACKUP_USER=sugang_backup
DB_BACKUP_PASSWORD=change-this-backup-password

# Redis
REDIS_IMAGE=redis:6-alpine
REDIS_CONTAINER_NAME=sugang-helper-redis
REDIS_PORT_HOST=6379
REDIS_PORT_CONTAINER=6379
REDIS_PASSWORD=password

# Monitoring
PROMETHEUS_CONTAINER_NAME=sugang-helper-prometheus
ALERTMANAGER_CONTAINER_NAME=sugang-helper-alertmanager
ALERTMANAGER_WEBHOOK_URL=https://discord.com/api/webhooks/replace-with-reviewed-webhook
PROMETHEUS_PORT_HOST=9090
PROMETHEUS_PORT_CONTAINER=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_CONTAINER_NAME=sugang-helper-grafana
GRAFANA_PORT_HOST=3001
GRAFANA_PORT_CONTAINER=3000

# Firebase (FCM) - required by server/docker-compose.yml volumes
FIREBASE_CONFIG_PATH=./secrets/firebase-key.json

# Persistent feedback attachment storage on the host. Back up this directory with database backups.
FILE_UPLOAD_DIR=/app/data/uploads

# Timezone
TZ=Asia/Seoul

# Docker bridge MTU: use 1500 locally; set to 9000 only on the OCI host after verifying jumbo frames.
DOCKER_NETWORK_MTU=1500
