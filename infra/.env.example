# Application image and local build paths
APP_IMAGE_NAME=sugang-helper-app
IMAGE_TAG=local
APP_CONTAINER_NAME=sugang-helper-app
APP_BUILD_CONTEXT=../apps/server
APP_ENV_FILE=../apps/server/.env.example
APP_PROD_CONFIG_PATH=../apps/server/src/main/resources/application-prod.yml
FIREBASE_CONFIG_PATH=./secrets/firebase-key.json
APP_BIND_ADDRESS=127.0.0.1
APP_PORT_HOST=8080
MANAGEMENT_BIND_ADDRESS=127.0.0.1
MANAGEMENT_PORT_HOST=8081

# Database (DB_DATA_DIR is the OCI block-volume mount in production)
DB_IMAGE=mysql:latest
DB_CONTAINER_NAME=sugang-helper-mysql
DB_DATABASE=sugang_helper
DB_DATA_DIR=/var/lib/jbnu-sugang-helper/mysql
DB_VOLUME_NAME=sugang-helper-db-data
DB_ROOT_PASSWORD=replace-with-local-db-root-secret
DB_JDBC_URL=jdbc:mysql://db:3306/sugang_helper?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_RUNTIME_USER=sugang_runtime
DB_RUNTIME_PASSWORD=replace-with-local-runtime-secret
DB_MIGRATOR_USER=sugang_migrator
DB_MIGRATOR_PASSWORD=replace-with-local-migrator-secret

# Redis is intentionally ephemeral in the minimal runtime.
REDIS_IMAGE=redis:latest
REDIS_CONTAINER_NAME=sugang-helper-redis
REDIS_PASSWORD=replace-with-local-redis-secret

# One-shot migration image
FLYWAY_IMAGE=flyway/flyway@sha256:8ace7d9825bb3ad1d6e14ee27b3a830b638ac841ba424b99b2d92aa65a99d484

# Production host readiness (replace in the root-only OCI runtime env)
API_HOST=api.example.test

# Persistent application uploads (not a database backup)
APP_UPLOAD_VOLUME_NAME=sugang-helper-app-uploads

# Optional production log search stack (enable with --profile observability)
LOKI_CONTAINER_NAME=sugang-helper-loki
LOKI_DATA_DIR=/var/lib/jbnu-sugang-helper/loki
LOKI_VOLUME_NAME=sugang-helper-loki-data
ALLOY_CONTAINER_NAME=sugang-helper-alloy
ALLOY_DATA_DIR=/var/lib/jbnu-sugang-helper/alloy
ALLOY_VOLUME_NAME=sugang-helper-alloy-data
GRAFANA_CONTAINER_NAME=sugang-helper-grafana
GRAFANA_DATA_DIR=/var/lib/jbnu-sugang-helper/grafana
GRAFANA_VOLUME_NAME=sugang-helper-grafana-data
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT_HOST=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-local-grafana-secret

# Application metrics are scraped by Prometheus; no host/container exporter is used.
PROMETHEUS_CONTAINER_NAME=sugang-helper-prometheus
PROMETHEUS_DATA_DIR=/var/lib/jbnu-sugang-helper/prometheus
PROMETHEUS_VOLUME_NAME=sugang-helper-prometheus-data
PROMETHEUS_RETENTION=15d

# Timezone and Docker bridge MTU
TZ=Asia/Seoul
DOCKER_NETWORK_MTU=1500
