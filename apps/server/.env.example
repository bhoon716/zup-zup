# Backend Application Properties
SPRING_PROFILES_ACTIVE=dev
LOG_FILE=./app.log
TZ=Asia/Seoul
FIREBASE_CONFIG_PATH=./src/main/resources/firebase/firebase-key.json
FILE_UPLOAD_DIR=/app/data/uploads

# Production datasource credentials are injected selectively by infra/docker-compose.yml.
# Do not add DB_ROOT_PASSWORD, DB_* or SPRING_FLYWAY_* values to this runtime file.

# Local Redis Connection (localhost)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

# Auth & OAuth2 Google Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.example.com/login/oauth2/code/google

# AWS Credentials (SES Email)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# JWT Token Secret
JWT_SECRET=replace-with-at-least-32-byte-jwt-secret

# App Web URL / CORS / Redirects
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:3000/onboarding
APP_OAUTH2_FAILURE_REDIRECT_URI=http://localhost:3000/login?error=unauthorized
APP_OAUTH2_AUTHORIZED_REDIRECT_URI=http://localhost:3000/api/login/oauth2/code/google

# Webpush Notification Keys
WEBPUSH_PUBLIC_KEY=your-webpush-public-key
WEBPUSH_PRIVATE_KEY=your-webpush-private-key
WEBPUSH_SUBJECT=mailto:admin@zup-zup.com

# Durable notification delivery / DLQ retention
APP_NOTIFICATION_OUTBOX_POLL_MS=5000
APP_NOTIFICATION_OUTBOX_BATCH_SIZE=50
APP_NOTIFICATION_OUTBOX_MAX_ATTEMPTS=5
APP_NOTIFICATION_OUTBOX_LEASE_SECONDS=60
APP_NOTIFICATION_OUTBOX_DLQ_RETENTION_DAYS=30
APP_NOTIFICATION_OUTBOX_DLQ_RETENTION_CRON="0 30 3 * * *"

# Discord Webhook & Bot Integration
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/v1/auth/discord/callback
